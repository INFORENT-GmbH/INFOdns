# Database
DB_ROOT_PASSWORD=changeme_root
DB_PASSWORD=changeme_infodns

# JWT
JWT_SECRET=changeme_jwt_secret_32chars_min
JWT_REFRESH_SECRET=changeme_refresh_secret_32chars_min

# BIND
# Comma-separated public IPs of the real secondary servers — used for also-notify
# ns1 (primary): 168.119.122.226   ns3: 5.78.139.169   ns2: 89.167.67.148
SECONDARY_IPS=5.78.139.169,89.167.67.148

# NS records to inject into every rendered zone (comma-separated FQDNs, trailing dot)
NS_RECORDS=ns1.ns.inforant.de.,ilreah.ns.inforant.de.,ulren.ns.inforant.de.

# SOA defaults
SOA_MNAME=ns1.ns.inforant.de.
SOA_RNAME=hostmaster.inforant.de.

# Public URL of the API (used by the Web UI)
PUBLIC_API_URL=http://localhost:3000

# SMTP (worker job notifications)
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=system@example.com
SMTP_PASS=changeme_smtp_password
SMTP_FROM=system@example.com
MAIL_FROM_NAME=INFOdns
MAIL_ADMIN_TO=admin@example.com

# Nameserver IPs for status checks
NS1_IP=80.243.196.37
NS2_IP=80.243.196.38
NS3_IP=80.243.196.39

# Runtime
NODE_ENV=production

# Support ticket IMAP import (reuse same mailbox as SMTP)
IMAP_ENABLED=false
IMAP_HOST=mail.example.com
IMAP_PORT=993
IMAP_USER=system@example.com
IMAP_PASS=changeme_smtp_password
IMAP_TLS=true
IMAP_POLL_INTERVAL_SECONDS=60

# Portal URL embedded in ticket notification emails
APP_PUBLIC_URL=https://dns.example.com
